# Server
PORT=5001

# PostgreSQL / Supabase (required for auth, sessions, community, and map data)
# Local:
#   DATABASE_URL=postgresql://user:password@localhost:5432/lemontree
# Supabase: Dashboard > Connect > Session pooler, include your DB password.
#   DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=

# JWT secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional import source override
OVERPASS_ENDPOINT=

# Make a .env file in backend directory and put env vars there.
# See ../SUPABASE_SETUP.md for the full setup flow.
